---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Welcome to Blog Techwemate</h1>
			<img src="/images/multiple-income-streams.jpg" alt="Multiple income streams" style="width: 100%; border-radius: 8px; margin: 1.5rem 0;" />
			<p>
				Your practical guide to building real income online — no hype, no shortcuts.
			</p>
			<p>
				Here you'll find honest, step-by-step content on affiliate marketing, digital
				products, dropshipping, and the tools and mindset it takes to build a sustainable
				online income, whether you're just starting out or scaling what you already have.
			</p>
			<p>
				New articles are published regularly. Browse the <a href="/blog">blog</a>, save
				what's useful, and start building.
			</p>
		</main>
		<Footer />
	</body>
</html>